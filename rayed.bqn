key тЖР {
  IsKey тЗР ("Key doesn't exist"!0тК╕тЙдтИз<тЯЬ512)тЪЗ0 @-╦ЬтНЯтЙдтЪЗ0тКв

  # key.IsPressed
  IsPressed тЗР {ЁЭХКkey:
    NeedsWindow@
    IsKey ЁЭХй
    (raylib.IsKeyPressed @-╦ЬтНЯтЙдтКв)тЪЗ0 ЁЭХй
  }
  # key.IsPressedRepeat
  IsPressedRepeat тЗР {ЁЭХКkey:
    NeedsWindow@
    IsKey ЁЭХй
    (raylib.IsKeyPressedRepeat @-╦ЬтНЯтЙдтКв)тЪЗ0 ЁЭХй
  }
  # key.IsReleased
  IsReleased тЗР {ЁЭХКkey:
    NeedsWindow@
    IsKey ЁЭХй
    (raylib.IsKeyReleased @-╦ЬтНЯтЙдтКв)тЪЗ0 ЁЭХй
  }
  # key.IsKeyUp
  IsKeyUp тЗР {ЁЭХКkey:
    NeedsWindow@
    IsKey ЁЭХй
    (raylib.IsKeyUp @-╦ЬтНЯтЙдтКв)тЪЗ0 ЁЭХй
  }
  # key.IsDown
  IsDown тЗР {
    NeedsWindow@
    IsKey ЁЭХй
    (raylib.IsKeyDown @-╦ЬтНЯтЙдтКв)тЪЗ0 ЁЭХй
  }
  # key.PressedKey
  PressedKey тЗР {ЁЭХд
    NeedsWindow@
    raylib.GetKeyPressedтЯитЯй
  }
  # key.PressedChar
  PressedChar тЗР {ЁЭХд
    NeedsWindow@
    @+raylib.GetcharPressedтЯитЯй
  }

  # Keyboard keys (US keyboard layout)
  # NOTE: Use GetKeyPressed() to allow redefining
  # required keys for alternative layouts

  # vars           Keycodes   Keys
  null          тЗР 0        # NULL, used for no key pressed

  # Alphanumeric keys
  apostrophe    тЗР 39       # '
  comma         тЗР 44       # ,
  minus         тЗР 45       # -
  period        тЗР 46       # .
  slash         тЗР 47       # /
  zeroтА┐oneтА┐twoтА┐threeтА┐fourтА┐fiveтА┐sixтА┐sevenтА┐eightтА┐nine тЗР 48+тЖХ10 # 0-9
  semicolon     тЗР 59       # ;
  equal         тЗР 61       # =
  aтА┐bтА┐cтА┐dтА┐eтА┐fтА┐gтА┐hтА┐iтА┐jтА┐kтА┐lтА┐mтА┐nтА┐oтА┐pтА┐qтА┐rтА┐sтА┐tтА┐uтА┐vтА┐wтА┐xтА┐yтА┐z тЗР 65+тЖХ26 # A-Z | a-z
  left_bracket  тЗР 91       # [
  backslash     тЗР 92       # \
  right_bracket тЗР 93       # ]
  grave         тЗР 96       # `

  # Function keys
  space         тЗР 32       # Space
  escape        тЗР 256      # Esc
  enter         тЗР 257      # Enter
  tab           тЗР 258      # Tab
  backspace     тЗР 259      # Backspace
  insert        тЗР 260      # Ins
  delete        тЗР 261      # Del
  right         тЗР 262      # Cursor right
  left          тЗР 263      # Cursor left
  down          тЗР 264      # Cursor down
  up            тЗР 265      # Cursor up
  page_up       тЗР 266      # Page up
  page_down     тЗР 267      # Page down
  home          тЗР 268      # Home
  end           тЗР 269      # End
  caps_lock     тЗР 280      # Caps lock
  scroll_lock   тЗР 281      # Scroll down
  print_screen  тЗР 283      # Print screen
  pause         тЗР 284      # Pause
  f1тА┐f2тА┐f3тА┐f4тА┐f5тА┐f6тА┐f7тА┐f8тА┐f9тА┐f10тА┐f11тА┐f12 тЗР 290+тЖХ12 # F1 - F12
  left_shift    тЗР 340      # Shift left
  left_control  тЗР 341      # Control left
  left_alt      тЗР 342      # Alt left
  left_super    тЗР 343      # Super left
  right_shift   тЗР 344      # Shift right
  right_control тЗР 345      # Control right
  right_alt     тЗР 346      # Alt right
  right_super   тЗР 347      # Super right
  kb_menu       тЗР 348      # KB menu

  keypad тЗР {
    num_lock    тЗР 282      # Num lock
    zeroтА┐oneтА┐twoтА┐threeтА┐fourтА┐fiveтА┐sixтА┐sevenтА┐eightтА┐nineтЖР320+тЖХ10 # Keypad 0-9
    decimal     тЗР 330      # Keypad .
    divide      тЗР 331      # Keypad /
    multiply    тЗР 332      # Keypad *
    subtract    тЗР 333      # Keypad -
    add         тЗР 334      # Keypad +
    enter       тЗР 335      # Keypad Enter
    equal       тЗР 336      # Keypad =
  }
  android тЗР {
    back        тЗР 4        # back button
    menu        тЗР 82       # menu button
    volume_up   тЗР 24       # volume up button
    volume_down тЗР 25       # volume down button
  }
}

# model
model тЖР {
  тЯи
    LoadFile тЛД Unload тЛД Draw тЛД LoadFromMesh
    GetBoundingBox тЛД DrawWires тЛД DrawWiresEx
  тЯйтЗР

  # model.LoadFile
  LoadFile тЖР {ЁЭХКfilePath:
    {!"Path given wasn't absolute ЁЭХйтЙб"тИ╛тАвReprЁЭХй}тНЯ("."тК╕тАвfile.AtтК╕тЙв)ЁЭХй
    {!"Couldn't find file at "тИ╛ЁЭХй}тНЯ(┬мтАвfile.Exists) ЁЭХй   #TODO verify if the error message errors when file doesn't exist.

    raylib.LoadModel тАвfile.At ЁЭХй
  }

  # model.Unload
  # Unload model (including meshes) from memory (RAM and/or VRAM)
  Unload тЖР {ЁЭХК:
    "model.Unload: wrong types as input"!ЁЭХйтАвTypeтК╕тКСтЯЬ"_icfmdn"тЪЗ0тК╕тЙб"iinnninn"тИ╛╦Ь<16теК'i'
    raylib.UnloadModel ЁЭХй
  }

  # model.Draw
  Draw тЖР {ЁЭХиЁЭХКmodelтА┐positionтА┐scaleтА┐tint:
    rotationAxisтА┐rotationAngleтЖРЁЭХитКг0тА┐1тА┐0тЛИ0
    scale теК╦ЬтЖй 3
    {
      "model.Draw: wrong types as input"!ЁЭХйтАвTypeтК╕тКСтЯЬ"_icfmdn"тЪЗ0тК╕тЙбтЯи
        "iii"тЛД"iii"тЛД"iinnninn"тИ╛╦Ь<16теК'i'тЛД"iii"тЛД"iii"тЛД'i'
      тЯй
      raylib.DrawModelEx ЁЭХй
    } rotationAxisтА┐rotationAngleтА┐modelтА┐positionтА┐scaleтА┐tint
  }


  LoadFromMesh тЖР {raylib.LoadModelFromMesh ЁЭХй}
  GetBoundingBox тЖР {raylib.GetModelBoundingBox ЁЭХй}
  DrawWires тЖР {raylib.DrawModelWires ЁЭХй}
  DrawWiresEx тЖР {raylib.DrawModelWiresEx ЁЭХй}
}

