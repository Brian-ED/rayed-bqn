key έΗΡ {
  IsKey έΘΡ ("Key doesn't exist"!0έΛ╕έΚνέΙπ<έθε512)έγΘ0 @-╦εέΞθέΚνέγΘ0έΛλ

  # key.IsPressed
  IsPressed έΘΡ {ΏζΧΛkey:
    NeedsWindow@
    IsKey ΏζΧσ
    (raylib.IsKeyPressed @-╦εέΞθέΚνέΛλ)έγΘ0 ΏζΧσ
  }
  # key.IsPressedRepeat
  IsPressedRepeat έΘΡ {ΏζΧΛkey:
    NeedsWindow@
    IsKey ΏζΧσ
    (raylib.IsKeyPressedRepeat @-╦εέΞθέΚνέΛλ)έγΘ0 ΏζΧσ
  }
  # key.IsReleased
  IsReleased έΘΡ {ΏζΧΛkey:
    NeedsWindow@
    IsKey ΏζΧσ
    (raylib.IsKeyReleased @-╦εέΞθέΚνέΛλ)έγΘ0 ΏζΧσ
  }
  # key.IsKeyUp
  IsKeyUp έΘΡ {ΏζΧΛkey:
    NeedsWindow@
    IsKey ΏζΧσ
    (raylib.IsKeyUp @-╦εέΞθέΚνέΛλ)έγΘ0 ΏζΧσ
  }
  # key.IsDown
  IsDown έΘΡ {
    NeedsWindow@
    IsKey ΏζΧσ
    (raylib.IsKeyDown @-╦εέΞθέΚνέΛλ)έγΘ0 ΏζΧσ
  }
  # key.PressedKey
  PressedKey έΘΡ {ΏζΧν
    NeedsWindow@
    raylib.GetKeyPressedέθρέθσ
  }
  # key.PressedChar
  PressedChar έΘΡ {ΏζΧν
    NeedsWindow@
    @+raylib.GetcharPressedέθρέθσ
  }

  # Keyboard keys (US keyboard layout)
  # NOTE: Use GetKeyPressed() to allow redefining
  # required keys for alternative layouts

  # vars           Keycodes   Keys
  null          έΘΡ 0        # NULL, used for no key pressed

  # Alphanumeric keys
  apostrophe    έΘΡ 39       # '
  comma         έΘΡ 44       # ,
  minus         έΘΡ 45       # -
  period        έΘΡ 46       # .
  slash         έΘΡ 47       # /
  zeroέΑ┐oneέΑ┐twoέΑ┐threeέΑ┐fourέΑ┐fiveέΑ┐sixέΑ┐sevenέΑ┐eightέΑ┐nine έΘΡ 48+έΗΧ10 # 0-9
  semicolon     έΘΡ 59       # ;
  equal         έΘΡ 61       # =
  aέΑ┐bέΑ┐cέΑ┐dέΑ┐eέΑ┐fέΑ┐gέΑ┐hέΑ┐iέΑ┐jέΑ┐kέΑ┐lέΑ┐mέΑ┐nέΑ┐oέΑ┐pέΑ┐qέΑ┐rέΑ┐sέΑ┐tέΑ┐uέΑ┐vέΑ┐wέΑ┐xέΑ┐yέΑ┐z έΘΡ 65+έΗΧ26 # A-Z | a-z
  left_bracket  έΘΡ 91       # [
  backslash     έΘΡ 92       # \
  right_bracket έΘΡ 93       # ]
  grave         έΘΡ 96       # `

  # Function keys
  space         έΘΡ 32       # Space
  escape        έΘΡ 256      # Esc
  enter         έΘΡ 257      # Enter
  tab           έΘΡ 258      # Tab
  backspace     έΘΡ 259      # Backspace
  insert        έΘΡ 260      # Ins
  delete        έΘΡ 261      # Del
  right         έΘΡ 262      # Cursor right
  left          έΘΡ 263      # Cursor left
  down          έΘΡ 264      # Cursor down
  up            έΘΡ 265      # Cursor up
  page_up       έΘΡ 266      # Page up
  page_down     έΘΡ 267      # Page down
  home          έΘΡ 268      # Home
  end           έΘΡ 269      # End
  caps_lock     έΘΡ 280      # Caps lock
  scroll_lock   έΘΡ 281      # Scroll down
  print_screen  έΘΡ 283      # Print screen
  pause         έΘΡ 284      # Pause
  f1έΑ┐f2έΑ┐f3έΑ┐f4έΑ┐f5έΑ┐f6έΑ┐f7έΑ┐f8έΑ┐f9έΑ┐f10έΑ┐f11έΑ┐f12 έΘΡ 290+έΗΧ12 # F1 - F12
  left_shift    έΘΡ 340      # Shift left
  left_control  έΘΡ 341      # Control left
  left_alt      έΘΡ 342      # Alt left
  left_super    έΘΡ 343      # Super left
  right_shift   έΘΡ 344      # Shift right
  right_control έΘΡ 345      # Control right
  right_alt     έΘΡ 346      # Alt right
  right_super   έΘΡ 347      # Super right
  kb_menu       έΘΡ 348      # KB menu

  keypad έΘΡ {
    num_lock    έΘΡ 282      # Num lock
    zeroέΑ┐oneέΑ┐twoέΑ┐threeέΑ┐fourέΑ┐fiveέΑ┐sixέΑ┐sevenέΑ┐eightέΑ┐nineέΗΡ320+έΗΧ10 # Keypad 0-9
    decimal     έΘΡ 330      # Keypad .
    divide      έΘΡ 331      # Keypad /
    multiply    έΘΡ 332      # Keypad *
    subtract    έΘΡ 333      # Keypad -
    add         έΘΡ 334      # Keypad +
    enter       έΘΡ 335      # Keypad Enter
    equal       έΘΡ 336      # Keypad =
  }
  android έΘΡ {
    back        έΘΡ 4        # back button
    menu        έΘΡ 82       # menu button
    volume_up   έΘΡ 24       # volume up button
    volume_down έΘΡ 25       # volume down button
  }
}

# model
model έΗΡ {
  έθρ
    LoadFile έΜΕ Unload έΜΕ Draw έΜΕ LoadFromMesh
    GetBoundingBox έΜΕ DrawWires έΜΕ DrawWiresEx
  έθσέΘΡ

  # model.LoadFile
  LoadFile έΗΡ {ΏζΧΛfilePath:
    {!"Path given wasn't absolute ΏζΧσέΚκ"έΙ╛έΑλReprΏζΧσ}έΞθ("."έΛ╕έΑλfile.AtέΛ╕έΚλ)ΏζΧσ
    {!"Couldn't find file at "έΙ╛ΏζΧσ}έΞθ(┬υέΑλfile.Exists) ΏζΧσ   #TODO verify if the error message errors when file doesn't exist.

    raylib.LoadModel έΑλfile.At ΏζΧσ
  }

  # model.Unload
  # Unload model (including meshes) from memory (RAM and/or VRAM)
  Unload έΗΡ {ΏζΧΛ:
    "model.Unload: wrong types as input"!ΏζΧσέΑλTypeέΛ╕έΛΣέθε"_icfmdn"έγΘ0έΛ╕έΚκ"iinnninn"έΙ╛╦ε<16έξΛ'i'
    raylib.UnloadModel ΏζΧσ
  }

  # model.Draw
  Draw έΗΡ {ΏζΧρΏζΧΛmodelέΑ┐positionέΑ┐scaleέΑ┐tint:
    rotationAxisέΑ┐rotationAngleέΗΡΏζΧρέΛμ0έΑ┐1έΑ┐0έΜΙ0
    scale έξΛ╦εέΗσ 3
    {
      "model.Draw: wrong types as input"!ΏζΧσέΑλTypeέΛ╕έΛΣέθε"_icfmdn"έγΘ0έΛ╕έΚκέθρ
        "iii"έΜΕ"iii"έΜΕ"iinnninn"έΙ╛╦ε<16έξΛ'i'έΜΕ"iii"έΜΕ"iii"έΜΕ'i'
      έθσ
      raylib.DrawModelEx ΏζΧσ
    } rotationAxisέΑ┐rotationAngleέΑ┐modelέΑ┐positionέΑ┐scaleέΑ┐tint
  }


  LoadFromMesh έΗΡ {raylib.LoadModelFromMesh ΏζΧσ}
  GetBoundingBox έΗΡ {raylib.GetModelBoundingBox ΏζΧσ}
  DrawWires έΗΡ {raylib.DrawModelWires ΏζΧσ}
  DrawWiresEx έΗΡ {raylib.DrawModelWiresEx ΏζΧσ}
}

