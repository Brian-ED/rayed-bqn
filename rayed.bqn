#  left_face_right  έΘΡ 2   # Gamepad left DPAD right button
#  left_face_down   έΘΡ 3   # Gamepad left DPAD down button
#  left_face_left   έΘΡ 4   # Gamepad left DPAD left button
#  right_face_up    έΘΡ 5   # Gamepad right button up (i.e. PS3: Triangle, Xbox: Y)
#  right_face_right έΘΡ 6   # Gamepad right button right (i.e. PS3: Square, Xbox: X)
#  right_face_down  έΘΡ 7   # Gamepad right button down (i.e. PS3: Cross, Xbox: A)
#  right_face_left  έΘΡ 8   # Gamepad right button left (i.e. PS3: Circle, Xbox: B)
#  left_trigger_1   έΘΡ 9   # Gamepad top/back trigger left (first), it could be a trailing button
#  left_trigger_2   έΘΡ 10  # Gamepad top/back trigger left (second), it could be a trailing button
#  right_trigger_1  έΘΡ 11  # Gamepad top/back trigger right (one), it could be a trailing button
#  right_trigger_2  έΘΡ 12  # Gamepad top/back trigger right (second), it could be a trailing button
#  middle_left      έΘΡ 13  # Gamepad center buttons, left one (i.e. PS3: Select)
#  middle           έΘΡ 14  # Gamepad center buttons, middle one (i.e. PS3: PS, Xbox: XBOX)
#  middle_right     έΘΡ 15  # Gamepad center buttons, right one (i.e. PS3: Start)
#  left_thumb       έΘΡ 16  # Gamepad joystick pressed button left
#  right_thumb      έΘΡ 17  # Gamepad joystick pressed button right
